# login.kv
<LoginScreen>:
    MDCard:
        size_hint: None, None
        size: "300dp", "500dp"
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        elevation: 2
        padding: "25dp"
        spacing: "25dp"
        orientation: "vertical"
        MDCard:
            pos_hint: {"center_x": 0.5, "center_y": 1}
            size_hint: None, None
            size: "100dp", "100dp"
            FitImage:
                source: "PNG/Logo/logo.png"
        MDLabel:
            text: "AbacaTo Login"
            font_style: "H5"
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]

        MDTextField:
            id: user_input
            hint_text: "Username"
            icon_right: "account"
            mode: "rectangle"

        MDTextField:
            id: pass_input
            hint_text: "Password"
            icon_right: "eye-off"
            mode: "rectangle"
            password: True

        MDRaisedButton:
            text: "LOG IN"
            pos_hint: {"center_x": 0.5}
            on_release: root.login_btn()

        MDTextButton:
            text: "Don't have an account? Register"
            pos_hint: {"center_x": 0.5}
            on_release: root.register_btn()