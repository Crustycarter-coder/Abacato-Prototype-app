#:import dp kivy.metrics.dp
ScreenManager:

    Screen:
        name: "login"

        MDBoxLayout:
            MDLabel:
                text: "Log in"

    Screen:
        name: "register"

        MDBoxLayout:
            MDLabel:
                text: "Register"


<UserManagerScreen>:
    name: "user_manager_scr"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.primary_color



        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "120dp"
            padding: "20dp"

            MDLabel:
                text: "AbacaTO"
                font_size: "32sp"
                bold: True
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: "Philippine Handicraft Marketplace"
                font_size: "18sp"
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 0.8

        MDBoxLayout:
            orientation: "vertical"
            md_bg_color: 1, 1, 1, 1
            radius: [24, 24, 0, 0]
            MDSeparator:

            MDScreenManager:
                id: signin_signup_manager

                LoginScr:
                    name: "log_in_scr"

                RegisterScr:
                    name: "register_scr"


<LoginScr>:

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(32)
        spacing: dp(16)
        md_bg_color: 1, 1, 1, 1

        MDTextField:
            id: enter_user
            hint_text: "Username"
            mode: "rectangle"
            icon_left: "account-outline"

        MDTextField:
            id: enter_pass
            hint_text: "Password"
            mode: "rectangle"
            password: True
            icon_left: "lock-outline"
            icon_right: "eye-off"

        Widget:
            size_hint_y: 1

        MDLabel:
            text: "Don't have an account? [ref=signup][color=ffb300]Sign Up[/color][/ref]"
            markup: True
            halign: "center"
            size_hint_y: None
            height: "24dp"

        MDRaisedButton:
            text: "Log in"
            pos_hint: {"center_x": 0.5}
            size_hint_x: 0.7
            on_release: root.perform_login()


<RegisterScr>:

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(20)
        spacing: dp(12)
        md_bg_color: 1, 1, 1, 1

        MDTextField:
            id: create_email
            hint_text: "Email"
            mode: "rectangle"
            icon_left: "email-outline"

        MDTextField:
            id: create_user
            hint_text: "Username"
            mode: "rectangle"
            icon_left: "account-outline"

        MDTextField:
            id: dob
            hint_text: "Date of Birth"
            mode: "rectangle"
            icon_right: "calendar"

        MDTextField:
            id: pswd
            hint_text: "Password"
            mode: "rectangle"
            password: True
            icon_left: "key-outline"
            icon_right: "eye-off"

        MDTextField:
            id: cmpswd
            hint_text: "Confirm Password"
            mode: "rectangle"
            password: True
            icon_left: "key-outline"
            icon_right: "eye-off"

        Widget:
            size_hint_y: 1

        MDRaisedButton:
            text: "Register"
            pos_hint: {"center_x": 0.5}
            size_hint_x: 0.7
            on_release: root.perform_register()


