
<InboxScreen>:
    BoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: "Inbox"
            anchor_title: "left"

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "46dp"
            spacing: "10dp"
            padding: [10, 7, 10, 7]

            canvas.before:
                Color:
                    rgba: 0, 0, 0, 1
                Line:
                    width: 0.7
                    points: self.x, self.y, self.x, self.y

            MDRectangleFlatButton:
                size: "100dp", "32dp"
                text: "Messages"
                pos_hint: {"x": 0, "center_y": 0.5}
                md_bg_color: 0.929, 0.831, 0.502, 1
                text_color: 1, 1, 1, 1
                font_size: "12sp"
                font_style: "Subtitle1"

            MDRectangleFlatButton:
                size: "100dp", "32dp"
                text: " + New Messages"
                pos_hint: {"x": 0, "center_y": 0.5}
                md_bg_color: 0, 0, 0, 0
                text_color: 0, 0, 0, 1
                font_size: "12sp"
                font_style: "Subtitle1"
                on_release: root.go_to_new_message()

        MDSeparator:
        ScrollView:
            size_hint: 1,1
            do_scroll_x: False
            MDList:
                id: inbox_list

<NewMessageScreen>:
    BoxLayout:
        orientation: "vertical"
        size_hint: 1, 1

        MDTopAppBar:
            title: "New Message"
            anchor_title: "left"
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1, 1, 1, 1
            left_action_items: [["arrow-left", lambda x: app.inbox_manager.go_back()]]

        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "100dp"
            padding: "8dp"
            spacing: "8dp"
            md_bg_color: 0.9, 0.9, 0.9, 1

            MDLabel:
                text: "Look for a Username"
                font_style: "Caption"
                size_hint_y: None
                height: "20dp"
                font_size: "18dp"

            MDTextField:
                id: username_input
                hint_text: ""
                mode: "rectangle"
                size_hint_y: None
                height: "44dp"
                on_text: root.filter_user(self.text)



        MDSeparator:

        ScrollView:
            size_hint: 1, 1
            MDList:
                id: result_list


<ChatScreen>:

    MDBoxLayout:

        orientation: "vertical"
        size_hint: 1, 1

        MDTopAppBar:
            id: chat_toolbar
            title: root.username
            anchor_title: "left"
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1, 1, 1, 1
            left_action_items: [["arrow-left", lambda x: app.inbox_manager.go_back()]]

        # Profile card shown at top if new chat
        ScrollView:
            size_hint: 1, 1
            do_scroll_x: False
            BoxLayout:
                id: chat_content
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: "10dp"
                spacing: "10dp"



        MDSeparator:

        # Message input bar at bottom
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "60dp"
            padding: "8dp"
            spacing: "8dp"
            md_bg_color: 0.9, 0.9, 0.9, 1

            MDTextField:
                id: message_input
                hint_text: "Message"
                mode: "rectangle"
                size_hint_y: None
                height: "44dp"
                pos_hint: {"center_y": 0.5}

            MDIconButton:
                icon: "send"
                theme_icon_color: "Custom"
                icon_color: app.theme_cls.primary_color
                post_hint: {"center_y": 0.5}
                on_release: root.send_message()



