<AddNewProductScreen>:
    md_bg_color: self.theme_cls.bg_normal

    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            title: "New Product Post"
            anchor_title: "left"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            md_bg_color: 0.95, 0.75, 0.2, 1
            elevation: 0

        MDScrollView:
            do_scroll_x: False
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                padding: "16dp"
                spacing: "20dp"

                MDLabel:
                    text: "Visuals"
                    markup: True
                    font_style: "H6"
                    bold: True

                MDGridLayout:
                    cols: 2
                    adaptive_height: True
                    spacing: "40dp"

                    MDCard:
                        size_hint: None, None
                        size: "170dp", "140dp"
                        ripple_behavior: True
                        md_bg_color: 0.95, 0.95, 0.95, 1
                        line_color: 0.8, 0.8, 0.8, 1
                        orientation: 'vertical'
                        padding: "10dp"
                        MDIcon:
                            icon: "image-plus"
                            pos_hint: {"center_x": .5, "center_y": 0.5}
                        MDLabel:
                            text: "Cover Photo"
                            halign: "center"
                            pos_hint: {"center_x": .5, "center_y": 0.3}
                            font_style: "Subtitle2"
                    MDGridLayout:
                        cols: 2
                        spacing: "10dp"
                        adaptive_size: True
                        MDBoxLayout:
                            orientation: "vertical"
                            adaptive_size: True
                            spacing: "10dp"
                            MDBoxLayout:
                                orientation: "horizontal"
                                adaptive_size: True
                                spacing: "10dp"
                                MDCard:
                                    size_hint: None, None
                                    size: "65dp", "65dp"
                                    md_bg_color: 0.95, 0.95, 0.95, 1
                                    elevation: 0
                                    MDRelativeLayout:
                                        MDIcon:
                                            icon: "plus"
                                            pos_hint: {"center_x": .5, "center_y": .5}

                                MDCard:
                                    size_hint: None, None
                                    size: "65dp", "65dp"
                                    md_bg_color: 0.95, 0.95, 0.95, 1
                                    elevation: 0
                                    MDRelativeLayout:
                                        MDIcon:
                                            icon: "plus"
                                            pos_hint: {"center_x": .5, "center_y": .5}

                            MDCard:
                                size_hint: None, None
                                size: "140dp", "65dp" # Matches exactly: 65 + 10 + 65
                                md_bg_color: 0.95, 0.95, 0.95, 1
                                elevation: 0
                                MDRelativeLayout:
                                    MDBoxLayout:
                                        orientation: 'horizontal'
                                        adaptive_size: True
                                        spacing: "8dp"
                                        pos_hint: {"center_x": .5, "center_y": .5}

                                        MDIcon:
                                            icon: "video-plus"
                                            pos_hint: {"center_y": .5}

                                        MDLabel:
                                            text: " Add video"
                                            font_style: "Caption"
                                            adaptive_size: True
                                            pos_hint: {"center_y": .5}

                MDCard:
                    orientation: 'vertical'
                    padding: "16dp"
                    spacing: "20dp"
                    adaptive_height: True
                    elevation: 1
                    radius: [15, ]

                    MDLabel:
                        text: "What are you selling?"
                        markup: True
                        bold: True
                    MDTextField:
                        hint_text: "Product title"
                        mode: "fill"
                        fill_color_normal: 0.9, 0.9, 0.9, 1

                    MDLabel:
                        text: "Category"
                        markup: True
                        bold: True

                    MDTextField:
                        id: select_category_field
                        hint_text: "Select Category"
                        mode: "fill"
                        fill_color_normal: 0.9, 0.9, 0.9, 1
                        icon_right: "menu-down"
                        on_focus:
                            if self.focus: root.open_menu()

                    MDLabel:
                        text: "Product Description"
                        markup: True
                        bold: True
                    MDTextField:
                        hint_text: "Write something about your product"
                        mode: "fill"
                        fill_color_normal: 0.9, 0.9, 0.9, 1
                        multiline: True
                        max_height: "150dp"

                # SECTION: Pricing
                MDCard:
                    orientation: 'vertical'
                    padding: "16dp"
                    spacing: "20dp"
                    adaptive_height: True
                    elevation: 1
                    radius: [15, ]

                    MDLabel:
                        text: "Pricing"
                        markup: True
                        bold: True

                    MDLabel:
                        text: "Unit Price"
                        font_style: "Caption"
                    MDTextField:
                        mode: "fill"
                        fill_color_normal: 0.9, 0.9, 0.9, 1

                    MDLabel:
                        text: "Min. Order Quantity"
                        font_style: "Caption"
                    MDTextField:
                        mode: "fill"
                        fill_color_normal: 0.9, 0.9, 0.9, 1

                MDFillRoundFlatButton:
                    text: "Submit"
                    font_size: "20sp"
                    md_bg_color: 0.95, 0.7, 0.1, 1 # Orange/Yellow
                    text_color: 1, 1, 1, 1
                    size_hint_x: 1
                    height: "56dp"
                    on_release: print("Product")
