#:import FitImage kivymd.uix.fitimage.FitImage

<HomeScreen>:

    BoxLayout:
        orientation: "vertical"
        size_hint: 1, 1
        MDTopAppBar:
            title: "AbacaTO"
            anchor_title: "center"
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1, 1, 1, 1
            left_action_items: [["menu", lambda x: root.go_to_menu()]]
            right_action_items: [["account-circle", lambda x: root.go_to_account()]]

        MDNavigationLayout:
            ScreenManager:
                MDScreen:
                    ScrollView:
                        size_hint: 1, 1
                        do_scroll_x: False
                        MDBoxLayout:
                            orientation: "vertical"
                            padding: [21,10,21,10]
                            spacing: "12dp"
                            size_hint_y: None
                            height: self.minimum_height
                            MDTextField:
                                hint_text: "Search any Product.."
                                mode: "rectangle"
                                size_hint_y: None
                                height: "48dp"
                                icon_left: "magnify"
                            MDFloatLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: "180dp"
                                md_bg_color: 0,0,0,0
                                radius: [12, 12, 12, 12]
                                FitImage:
                                    source: "PNG/CategoriesPNG/Abaca/Abaca fiber product1.jpg"
                                    radius: [12, 12, 12, 12]
                                    size_hint: 1,1
                                    pos_hint: {"x": 0, "y": 0}
                                MDBoxLayout:
                                    size_hint: 1,1
                                    pos_hint: {"x": 0, "y": 0}
                                    md_bg_color: 0,0,0,0.2
                                MDBoxLayout:
                                    orientation: "vertical"
                                    spacing: "5dp"
                                    padding: "25dp"
                                    pos_hint: {'center_y': 0.5}
                                    MDLabel:
                                        text: "50-40% OFF"
                                        theme_text_color: "Custom"
                                        text_color: 1,1,1,1
                                        font_size: "18sp"
                                        bold: True
                                    MDLabel:
                                        text: "Now in (product)\nAll colours"
                                        theme_text_color: "Custom"
                                        text_color: 1,1,1,1
                                        font_size: "12sp"
                                    MDBoxLayout:
                                        orientation: 'horizontal'
                                        padding: "5dp"
                                        size_hint: None,None
                                        size: "100dp","32dp"
                                        spacing: "5dp"
                                        line_color: 1,1,1,1

                                        MDLabel:
                                            text: "Shop Now"
                                            theme_text_color: "Custom"
                                            text_color: 1,1,1,1
                                            font_size: "12sp"
                                            halign: "left"
                                            pos_hint: {"center_y": 0.5}
                                        MDIcon:
                                            icon: 'arrow-right-thin'
                                            size: "18dp","18dp"
                                            pos_hint: {"center_y": 0.5}
                                            theme_text_color: "Custom"
                                            text_color: 1,1,1,1




                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y:None
                                height: "84dp"
                                spacing: "40dp"

                                MDCard:
                                    orientation: "vertical"
                                    md_bg_color: 0, 0, 0, 0
                                    elevation: 0
                                    spacing: "1dp"
                                    on_release: root.go_to_shop()
                                    FitImage:
                                        source: "ICONS/Shop4.png"
                                        radius: [10, 10, 0, 0]
                                    MDLabel:
                                        text: "Shop"
                                        halign: "center"
                                        valign: "center"
                                        size_hint_y: 0.35
                                        font_size: "9sp"
                                        bold: True

                                MDCard:
                                    orientation: "vertical"
                                    md_bg_color: 0, 0, 0, 0
                                    elevation: 0
                                    on_release: root.go_to_communitychat()
                                    FitImage:
                                        source: "ICONS/community chat icon.png"

                                        radius: [10, 10, 0, 0]
                                    MDLabel:
                                        text: "Community\nChat"
                                        halign: "center"
                                        valign: "center"
                                        size_hint_y: 0.35
                                        font_size: "9sp"
                                        bold: True

                                MDCard:
                                    orientation: "vertical"
                                    md_bg_color: 0, 0, 0, 0
                                    elevation: 0
                                    on_release: root.go_to_rfq()
                                    FitImage:
                                        source: "ICONS/Taget quotation 4 icon.png"

                                        radius: [10, 10, 0, 0]
                                    MDLabel:
                                        text: "Request for\nQuotation"
                                        halign: "center"
                                        valign: "center"
                                        size_hint_y: 0.35
                                        font_size: "9sp"
                                        bold: True

                                MDCard:
                                    orientation: "vertical"
                                    md_bg_color: 0, 0, 0, 0
                                    elevation: 0
                                    on_release: root.go_to_buyoffers()
                                    FitImage:
                                        source: "ICONS/Buy offer icon.png"

                                        radius: [10, 10, 0, 0]
                                    MDLabel:
                                        text: "Buy\nOffers"
                                        halign: "center"
                                        valign: "center"
                                        size_hint_y: 0.35
                                        font_size: "9sp"
                                        bold: True

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: "30dp"
                                MDIcon:
                                    icon: "fire"
                                    size_hint: None,None
                                    size: "13dp", "13dp"
                                    theme_text_color: "Custom"
                                    text_color: 1, 0, 0, 1
                                    pos_hint: {"x": 0, "center_y": 0.5}

                                MDLabel:
                                    text: "Hot Products By Categories"
                                    valign: "center"
                                    bold: True
                                    font_size: "13sp"


                            MDCard:
                                orientation: "vertical"
                                size_hint_y: None
                                height: "200dp"
                                radius: [12, 12, 12, 12]
                                md_bg_color: 0.90, 0.87, 0.79, 1
                                padding: "10dp"
                                spacing: "8dp"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    size_hint_y: None
                                    height: "30dp"
                                    MDLabel:
                                        text: "Textiles Products"
                                        bold: True
                                        font_size: "13sp"
                                    MDLabel:
                                        text: "View All"
                                        halign: "right"
                                        font_size: "11sp"
                                        theme_text_color: "Secondary"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    spacing: "10dp"
                                    size_hint_y: None
                                    height: "140dp"

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Textile/Product1/garment.png"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Filipiniana\nGarments"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber product1.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True
                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Textile/Product3/barong.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Barong\nTextile"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True
                            MDCard:
                                orientation: "vertical"
                                size_hint_y: None
                                height: "200dp"
                                radius: [12, 12, 12, 12]
                                md_bg_color: 0.733, 0.561, 0.275, 1
                                padding: "10dp"
                                spacing: "8dp"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    size_hint_y: None
                                    height: "30dp"
                                    MDLabel:
                                        text: "Abaca Products"
                                        bold: True
                                        font_size: "13sp"
                                    MDLabel:
                                        text: "View All"
                                        halign: "right"
                                        font_size: "11sp"
                                        theme_text_color: "Secondary"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    spacing: "10dp"
                                    size_hint_y: None
                                    height: "140dp"

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber 4.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca Fiber product5.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True
                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber product 3.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Pure Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True
                            MDCard:
                                orientation: "vertical"
                                size_hint_y: None
                                height: "200dp"
                                radius: [12, 12, 12, 12]
                                md_bg_color: 0.733, 0.561, 0.275, 1
                                padding: "10dp"
                                spacing: "8dp"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    size_hint_y: None
                                    height: "30dp"
                                    MDLabel:
                                        text: "Abaca Products"
                                        bold: True
                                        font_size: "13sp"
                                    MDLabel:
                                        text: "View All"
                                        halign: "right"
                                        font_size: "11sp"
                                        theme_text_color: "Secondary"

                                MDBoxLayout:
                                    orientation: "horizontal"
                                    spacing: "10dp"
                                    size_hint_y: None
                                    height: "140dp"

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber 4.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True

                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca Fiber product5.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True
                                    MDCard:
                                        orientation: "vertical"
                                        md_bg_color: 1, 1, 1, 1
                                        radius: [10, 10, 10, 10]
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber product 3.jpg"
                                            size_hint_y: 0.65
                                            radius: [10, 10, 0, 0]
                                        MDLabel:
                                            text: "Pure Abaca\nFiber"
                                            halign: "center"
                                            valign: "center"
                                            size_hint_y: 0.35
                                            font_size: "9sp"
                                            bold: True



                            MDGridLayout:
                                cols: 2
                                spacing: "15dp"
                                padding: "20dp"
                                size_hint_y: None
                                height: self.minimum_height
                                md_bg_color: 0.96, 0.96, 0.96, 1
                                MDCard:
                                    orientation: "vertical"
                                    spacing: "10dp"
                                    md_bg_color: 1,1,1,1
                                    size_hint: None,None
                                    size: "170dp", "296dp"
                                    radius: [12, 12, 12, 12]
                                    padding: [9,20,9,10]
                                    on_release: root.go_to_productsinfo()
                                    MDCard:
                                        size_hint: None, None
                                        size: "143dp", "171dp"
                                        radius: [8,8,8,8]
                                        pos_hint: {"center_x": 0.5}
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca Fiber product5.jpg"
                                            radius: [8,8,8,8]
                                    MDBoxLayout:
                                        orientation: "vertical"
                                        spacing: "10dp"
                                        size_hint_y: None
                                        height: "90dp"
                                        MDLabel:
                                            text: "Raw Abaca Fiber/\nManila Hemp Graded"
                                            font_size: "12sp"
                                            theme_text_color: "Custom"
                                            text_color: 0, 0, 0, 1
                                        MDLabel:
                                            text: "₱270.00"
                                            font_size: "15sp"
                                            bold: True
                                            theme_text_color: "Custom"
                                            text_color: 0,0,0,1
                                        MDBoxLayout:
                                            orientation: "horizontal"
                                            spacing: "5dp"
                                            MDLabel:
                                                icon: "star"
                                                size_hint_y: None
                                                height: "10dp"
                                            MDLabel:
                                                text: "5.0"
                                                font_size: "10sp"
                                                theme_text_color: "Custom"
                                                text_color: 0,0,0,1
                                            MDLabel:
                                                icon: "map-marker"
                                                size_hint_y: None
                                                height: "10dp"
                                            MDLabel:
                                                text: "Cavite"
                                                font_size: "10sp"
                                                theme_text_color: "Custom"
                                                text_color: 0,0,0,1
                                MDCard:
                                    orientation: "vertical"
                                    spacing: "10dp"
                                    md_bg_color: 1,1,1,1
                                    size_hint: None,None
                                    size: "170dp", "296dp"
                                    radius: [12, 12, 12, 12]
                                    padding: [9,20,9,10]
                                    on_release: root.go_to_productsinfo()
                                    MDCard:
                                        size_hint: None, None
                                        size: "143dp", "171dp"
                                        radius: [8,8,8,8]
                                        pos_hint: {"center_x": 0.5}
                                        FitImage:
                                            source: "PNG/CategoriesPNG/Abaca/Abaca Fiber product5.jpg"
                                            radius: [8,8,8,8]
                                    MDBoxLayout:
                                        orientation: "vertical"
                                        spacing: "10dp"
                                        size_hint_y: None
                                        height: "90dp"
                                        MDLabel:
                                            text: "Raw Abaca Fiber/\nManila Hemp Graded"
                                            font_size: "12sp"
                                            theme_text_color: "Custom"
                                            text_color: 0, 0, 0, 1
                                        MDLabel:
                                            text: "₱270.00"
                                            font_size: "15sp"
                                            bold: True
                                            theme_text_color: "Custom"
                                            text_color: 0,0,0,1
                                        MDBoxLayout:
                                            orientation: "horizontal"
                                            spacing: "5dp"
                                            MDLabel:
                                                icon: "star"
                                                size_hint_y: None
                                                height: "10dp"
                                            MDLabel:
                                                text: "5.0"
                                                font_size: "10sp"
                                                theme_text_color: "Custom"
                                                text_color: 0,0,0,1
                                            MDLabel:
                                                icon: "map-marker"
                                                size_hint_y: None
                                                height: "10dp"
                                            MDLabel:
                                                text: "Cavite"
                                                font_size: "10sp"
                                                theme_text_color: "Custom"
                                                text_color: 0,0,0,1
