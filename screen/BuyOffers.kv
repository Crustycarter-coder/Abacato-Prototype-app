#:import FitImage kivymd.uix.fitimage.FitImage

<BuyOffersScreen>:
    BoxLayout:
        orientation: "vertical"
        spacing: "5dp"

        MDTopAppBar:
            title: "Buy Offers"
            anchor_title: "left"
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 0, 0, 0, 1
            left_action_items: [["arrow-left", lambda x: app.go_back()]]

        # Search bar
        BoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: "8dp", "4dp"

            MDTextField:
                hint_text: "Find anything"
                mode: "rectangle"
                size_hint_y: None
                height: "48dp"
                icon_left: "magnify"

        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: "8dp"
                padding: "8dp"
                md_bg_color: 0.96, 0.96, 0.96, 1

                # Post Card
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: "380dp"
                    padding: "10dp"
                    spacing: "8dp"
                    md_bg_color: 1, 1, 1, 1
                    radius: [12, 12, 12, 12]

                    # User row
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "48dp"
                        spacing: "8dp"

                        # Avatar
                        MDCard:
                            size_hint: None, None
                            size: "44dp", "44dp"
                            radius: [22, 22, 22, 22]
                            pos_hint: {"center_y": 0.5}
                            FitImage:
                                source: "PNG/Users/catherineacc2.png"
                                radius: [22, 22, 22, 22]

                        # Username
                        MDLabel:
                            text: "Catherine"
                            font_size: "14sp"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0, 0, 0, 1
                            pos_hint: {"center_y": 0.5}

                        # Three dots
                        MDIconButton:
                            icon: "dots-vertical"
                            pos_hint: {"center_y": 0.5}
                            theme_icon_color: "Custom"
                            icon_color: 0, 0, 0, 1

                    # Post text
                    MDLabel:
                        text: "Let's trade barong, this is my barong made of abaca fiber."
                        font_size: "15sp"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 0, 0, 0, 1
                        size_hint_y: None
                        height: "28dp"

                    # Post image
                    MDCard:
                        size_hint: 1, None
                        height: "220dp"
                        radius: [8, 8, 8, 8]

                        FitImage:
                            source: "PNG/CategoriesPNG/Textile/Product3/barong.jpg"
                            radius: [8, 8, 8, 8]

                    # Action buttons row
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "40dp"
                        spacing: "8dp"

                        # Contact Buyer
                        MDRaisedButton:
                            text: "Contact Buyer"
                            size_hint: None, None
                            size: "150dp", "36dp"
                            md_bg_color: app.theme_cls.primary_color
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}

                        Widget:
                            size_hint_x: 1

                        # Chat count button
                        MDCard:
                            orientation: "horizontal"
                            size_hint: None, None
                            size: "72dp", "36dp"
                            radius: [18, 18, 18, 18]
                            padding: "5dp"
                            spacing: "4dp"
                            md_bg_color: 1,1,1,1
                            pos_hint: {"center_y": 0.5}
                            canvas.after:
                                Color:
                                    rgba: 1, 0.76, 0.03, 1  # amber
                                Line:
                                    width: 1.2
                                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            MDIconButton:
                                icon: "chat-outline"
                                size_hint: None, None
                                size: "24dp", "24dp"
                                pos_hint: {"x": 0, "center_y": 0.5}
                                theme_icon_color: "Custom"
                                icon_color: 0, 0, 0, 1
                            MDLabel:
                                text: "4"
                                font_size: "12sp"
                                pos_hint: {"center_y": 0.5}
                                theme_text_color: "Custom"
                                text_color: 0, 0, 0, 1

                        # Share count button
                        MDCard:
                            orientation: "horizontal"
                            size_hint: None, None
                            size: "72dp", "36dp"
                            radius: [18, 18, 18, 18]
                            padding: "5dp"
                            md_bg_color:1,1,1,1
                            pos_hint: {"center_y": 0.5}
                            canvas.after:
                                Color:
                                    rgba: 1, 0.76, 0.03, 1  # amber
                                Line:
                                    width: 1.2
                                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            MDIconButton:
                                icon: "share-outline"
                                size_hint: None, None
                                size: "24dp", "24dp"
                                pos_hint: {"x": 0, "center_y": 0.5}
                                theme_icon_color: "Custom"
                                icon_color: 0, 0, 0, 1

                            MDLabel:
                                text: "6"
                                font_size: "12sp"
                                pos_hint: {"center_y": 0.5}
                                theme_text_color: "Custom"
                                text_color: 0, 0, 0, 1
                MDCard:
                    orientation: "vertical"
                    size_hint_y: None
                    height: "380dp"
                    padding: "10dp"
                    spacing: "8dp"
                    md_bg_color: 1, 1, 1, 1
                    radius: [12, 12, 12, 12]

                    # User row
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "48dp"
                        spacing: "8dp"

                        # Avatar
                        MDCard:
                            size_hint: None, None
                            size: "44dp", "44dp"
                            radius: [22, 22, 22, 22]
                            pos_hint: {"center_y": 0.5}
                            FitImage:
                                source: "PNG/Users/pramanixacc.png"
                                radius: [22, 22, 22, 22]

                        # Username
                        MDLabel:
                            text: "Pramanix"
                            font_size: "14sp"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0, 0, 0, 1
                            pos_hint: {"center_y": 0.5}

                        # Three dots
                        MDIconButton:
                            icon: "dots-vertical"
                            pos_hint: {"center_y": 0.5}
                            theme_icon_color: "Custom"
                            icon_color: 0, 0, 0, 1

                    # Post text
                    MDLabel:
                        text: "I want to buy abaca fiber like this."
                        font_size: "15sp"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 0, 0, 0, 1
                        size_hint_y: None
                        height: "28dp"

                    # Post image
                    MDCard:
                        size_hint: 1, None
                        height: "220dp"
                        radius: [8, 8, 8, 8]

                        FitImage:
                            source: "PNG/CategoriesPNG/Abaca/Abaca fiber product1.jpg"
                            radius: [8, 8, 8, 8]

                    # Action buttons row
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "40dp"
                        spacing: "8dp"

                        # Contact Buyer
                        MDRaisedButton:
                            text: "Contact Buyer"
                            size_hint: None, None
                            size: "150dp", "36dp"
                            md_bg_color: app.theme_cls.primary_color
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}

                        Widget:
                            size_hint_x: 1

                        # Chat count button
                        MDCard:
                            orientation: "horizontal"
                            size_hint: None, None
                            size: "72dp", "36dp"
                            radius: [18, 18, 18, 18]
                            padding: "5dp"
                            spacing: "4dp"
                            md_bg_color: 1,1,1,1
                            pos_hint: {"center_y": 0.5}
                            canvas.after:
                                Color:
                                    rgba: 1, 0.76, 0.03, 1  # amber
                                Line:
                                    width: 1.2
                                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            MDIconButton:
                                icon: "chat-outline"
                                size_hint: None, None
                                size: "24dp", "24dp"
                                pos_hint: {"x": 0, "center_y": 0.5}
                                theme_icon_color: "Custom"
                                icon_color: 0, 0, 0, 1
                            MDLabel:
                                text: "2"
                                font_size: "12sp"
                                pos_hint: {"center_y": 0.5}
                                theme_text_color: "Custom"
                                text_color: 0, 0, 0, 1

                        # Share count button
                        MDCard:
                            orientation: "horizontal"
                            size_hint: None, None
                            size: "72dp", "36dp"
                            radius: [18, 18, 18, 18]
                            padding: "5dp"
                            md_bg_color:1,1,1,1
                            pos_hint: {"center_y": 0.5}
                            canvas.after:
                                Color:
                                    rgba: 1, 0.76, 0.03, 1  # amber
                                Line:
                                    width: 1.2
                                    rounded_rectangle: (self.x, self.y, self.width, self.height, 8)
                            MDIconButton:
                                icon: "share-outline"
                                size_hint: None, None
                                size: "24dp", "24dp"
                                pos_hint: {"x": 0, "center_y": 0.5}
                                theme_icon_color: "Custom"
                                icon_color: 0, 0, 0, 1

                            MDLabel:
                                text: "3"
                                font_size: "12sp"
                                pos_hint: {"center_y": 0.5}
                                theme_text_color: "Custom"
                                text_color: 0, 0, 0, 1











